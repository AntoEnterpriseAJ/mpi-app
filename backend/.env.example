# Copy this file to .env and uncomment the appropriate line for your setup.
# NEVER commit the actual .env file to Git.

# Option A: Local native PostgreSQL (native backend setup, port 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mpi_db

# Option B: Docker Compose (when running inside the api container)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/mpi_db
